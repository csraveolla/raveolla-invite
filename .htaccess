RewriteEngine On

# Map /assets/* → /tema/assets/*
RewriteRule ^assets/(.+)$ tema/assets/$1 [L,QSA]

# Serve admin panel di /rsvp-admin (tanpa redirect)
RewriteRule ^rsvp-admin/?$ rsvp-admin/super-adm.html [L]

# Serve client panel di /rsvp-client (tanpa redirect)
RewriteRule ^rsvp-client/?$ rsvp-client/client-adm.html [L]

# Skip file & folder yang ada
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Route slug bersih ke PHP router
RewriteRule ^([a-zA-Z0-9_-]+)$ tema/index.php?slug=$1 [QSA,L]
